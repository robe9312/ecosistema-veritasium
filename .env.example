# ============================================================
#  .env.example — Configuración de Entorno Veritasium
#  Copia este archivo como '.env' y completa tus claves
# ============================================================

# 🤖 GROQ AI (Obtén tu key en https://console.groq.com)
GROQ_API_KEY=gsk_tu_clave_aqui

# 💰 SOLANA WALLET (Clave privada en Base58 o array de bytes)
# ⚠️ ADVERTENCIA: Usa una wallet dedicada con poco balance.
SOLANA_PRIVATE_KEY=tu_clave_privada_aqui

# 🌐 SOLANA RPC URL (Recomendado: Helius, QuickNode o Alchemy)
SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=tu_key_aqui

# 💸 WALLETS DE DESTINO
PROFIT_WALLET=7xKXtg2CW87d97TXJSDpbD5jBkheTqA83TZRuJosgAsU
RISK_HUNTER_WALLET=tu_nueva_wallet_bot3_aqui

# ⚙️ MODO DE OPERACIÓN (live | dry-run)
# Usa 'dry-run' para simular sin transacciones reales.
BOT_MODE=dry-run

# 🚨 NOTIFICACIONES (Opcional)
WEBHOOK_URL=https://discord.com/api/webhooks/...
